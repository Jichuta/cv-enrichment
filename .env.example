# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Security ──────────────────────────────────────────────────────────────────
# Bearer token required on all protected endpoints
# In production: use a strong secret and validate real JWTs
API_SECRET_KEY=change-me-in-production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * to allow all
CORS_ORIGINS=["*"]

# ── Databricks ────────────────────────────────────────────────────────────────
DATABRICKS_HOST=https://dbc-ee3269b0-d8c2.cloud.databricks.com
DATABRICKS_TOKEN=your-databricks-token-here

# ── Databricks Jobs (async job-based enrichment) ──────────────────────────────
# Job ID for the CV enrichment Databricks job
DATABRICKS_ENRICHMENT_JOB_ID=641521814626867
# How often to poll for job completion (seconds)
DATABRICKS_JOB_POLL_INTERVAL_SECS=5
# Max time to wait for a job before timing out (seconds)
DATABRICKS_JOB_TIMEOUT_SECS=300

# ── Databricks LLM (direct model serving) ─────────────────────────────────────
# Model name as shown in Databricks serving endpoints
DATABRICKS_LLM_MODEL=databricks-gemma-3-12b
DATABRICKS_LLM_MAX_TOKENS=5000
DATABRICKS_LLM_TEMPERATURE=0.0
